modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node server/index.js"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 4001
externalPort = 3000

[[ports]]
localPort = 4567
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["node", "server/index.js"]

[userenv]

[userenv.shared]
VITE_GOOGLE_CLIENT_ID = "19856102489-ajcgo0guof71q231fig5lk8dm4vfk7mv.apps.googleusercontent.com"
PORT = "3001"
NODE_ENV = "development"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
