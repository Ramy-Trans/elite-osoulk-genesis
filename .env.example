# ─── Osoulk — Environment Variables ──────────────────────────────────────────
# On Hostinger: copy this file to .env.production and fill in your values,
# OR set these as environment variables before running `npm run build`.
#
# On Replit: add these as Secrets in the Replit Secrets panel.

# ─── Supabase (required — frontend uses these at build time via Vite) ─────────
# Get these from: Supabase Dashboard → Project Settings → API
# IMPORTANT: VITE_SUPABASE_URL must be the base URL only, e.g.:
#   https://your-project-id.supabase.co    ← CORRECT
#   https://your-project-id.supabase.co/rest/v1/  ← WRONG
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server (only needed if running the Express API server) ──────────────────
PORT=3001
NODE_ENV=production

# ─── Admin (only needed for Express server mode) ─────────────────────────────
ADMIN_PASSWORD=osoulk2026
