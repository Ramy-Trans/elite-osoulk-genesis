# ─── Osoulk — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values before deploying to Hostinger.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
SITE_URL=https://yourdomain.com

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=osoulk2026

# ─── MySQL Database (Hostinger) ──────────────────────────────────────────────
# Leave DB_HOST blank to use JSON file storage (development / Replit).
# Set DB_HOST to your Hostinger MySQL host to enable MySQL mode.
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=osoulk_db
DB_PORT=3306
