# ─── Osoulk — Environment Variables ──────────────────────────────────────────
# On Hostinger (frontend build): copy this file to .env.production and fill in
# values before running `npm run build`.
# On Replit (backend): add these as Secrets in the Replit Secrets panel.

# ─── Frontend API base (CRITICAL for Hostinger → Replit split deployment) ────
# When the frontend is hosted on Hostinger and the API runs on Replit,
# set this to your deployed Replit backend URL (no trailing slash):
#   https://your-app-name.replit.app
#
# Leave empty ("") if frontend and backend are served from the same origin.
# This value is baked into the JS bundle at build time by Vite.
VITE_API_BASE=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Admin password ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=osoulk2026

# ─── MySQL (Hostinger DB — optional, falls back to JSON files if not set) ─────
# DB_HOST=your-mysql-host.hostinger.com
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=osoulk_db
# DB_PORT=3306
